{
  "name": "squad-admin-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "clean": "pnpm -r exec rimraf dist .next node_modules || true",
    "db:generate": "pnpm --filter @squad-admin/database prisma:generate",
    "db:migrate": "pnpm --filter @squad-admin/database prisma:migrate",
    "db:deploy": "pnpm --filter @squad-admin/database prisma:deploy",
    "db:studio": "pnpm --filter @squad-admin/database prisma:studio",
    "db:reset": "pnpm --filter @squad-admin/database prisma:reset",
    "db:seed": "pnpm --filter @squad-admin/database seed",
    "backend:dev": "pnpm --filter @squad-admin/backend dev",
    "backend:build": "pnpm --filter @squad-admin/backend build",
    "bot:dev": "pnpm --filter @squad-admin/bot dev",
    "bot:build": "pnpm --filter @squad-admin/bot build",
    "frontend:dev": "pnpm --filter @squad-admin/frontend dev",
    "frontend:build": "pnpm --filter @squad-admin/frontend build",
    "import:bans": "pnpm --filter @squad-admin/backend import:bans",
    "import:admins": "pnpm --filter @squad-admin/backend import:admins",
    "check:commit": "pnpm lint && pnpm build",
    "prepare": "husky",
    "clean:win": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Get-ChildItem -Path . -Include node_modules,dist,build,.next,.turbo,coverage,.cache -Recurse -Directory | Remove-Item -Recurse -Force\"",
    "clean:mac": "find . \\( -name node_modules -o -name dist -o -name build -o -name .next -o -name .turbo -o -name coverage -o -name .cache \\) -type d -prune -exec rm -rf '{}' +"
  },
  "devDependencies": {
    "@conarti/eslint-plugin-feature-sliced": "^1.0.5",
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^16.2.6",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-expressions": "^1.3.2",
    "eslint-plugin-lodash": "^8.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "turbo": "^2.6.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  }
}
