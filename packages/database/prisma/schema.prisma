datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

enum UserRole {
  CAMERA
  TECH_ADMINISTRATOR
  VIP
  INTERN
  MODERATOR
  ADMINISTRATOR
}

enum BanTargetType {
  STEAM_ID
  EOS_ID
}

enum BanStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum PunishmentType {
  WARN
}

enum PlayerSessionStatus {
  ONLINE
  CLOSED
  STALE
}

model User {
  id          String    @id @default(uuid())
  steamId     String    @unique
  displayName String?
  avatarUrl   String?
  profileUrl  String?
  role        UserRole?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Player {
  id              String   @id @default(uuid())
  steamId         String   @unique
  eosId           String?  @unique
  lastName        String?
  lastSeenServerId Int?
  firstSeenAt     DateTime @default(now())
  lastSeenAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  names           PlayerName[]
  sessions        PlayerSession[]
  punishments     Punishment[]
  externalProfile PlayerExternalProfile?

  @@index([lastName])
  @@index([lastSeenServerId])
}

model PlayerName {
  id          String   @id @default(uuid())
  playerId    String
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  nickname    String
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  timesSeen   Int      @default(1)
  source      String   @default("server")

  @@unique([playerId, nickname])
  @@index([nickname])
}

model PlayerSession {
  id             String              @id @default(uuid())
  playerId       String
  player         Player              @relation(fields: [playerId], references: [id], onDelete: Cascade)
  serverId       Int
  connectedAt    DateTime            @default(now())
  disconnectedAt DateTime?
  status         PlayerSessionStatus @default(ONLINE)
  connectRaw     String?
  disconnectRaw  String?
  lastKnownName  String?
  lastKnownEosId String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([playerId])
  @@index([serverId, status])
  @@index([connectedAt])
}

model PlayerExternalProfile {
  id              String   @id @default(uuid())
  playerId         String   @unique
  player           Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  steamId          String   @unique
  personaName      String?
  profileUrl       String?
  avatarUrl        String?
  countryCode      String?
  steamCreatedAt   DateTime?
  squadPlaytimeMin Int?
  totalPlaytimeMin Int?
  isPrivate        Boolean  @default(false)
  raw              Json?
  lastFetchedAt    DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Punishment {
  id            String         @id @default(uuid())
  type          PunishmentType
  playerId      String?
  player        Player?        @relation(fields: [playerId], references: [id], onDelete: SetNull)
  steamId       String?
  eosId         String?
  nickname      String?
  reason        String
  createdById   String?
  createdByName String?
  createdAt     DateTime       @default(now())

  @@index([type])
  @@index([steamId])
  @@index([eosId])
  @@index([nickname])
  @@index([createdAt])
}

model Ban {
  id                    String        @id @default(uuid())
  targetType            BanTargetType
  targetValue           String
  normalizedTargetValue String
  targetNameSnapshot    String?

  reason                String
  status                BanStatus     @default(ACTIVE)
  expiresAt             DateTime?

  createdById           String?
  createdByName         String?
  revokedById           String?
  revokedByName         String?
  revokedAt             DateTime?
  revokeReason          String?

  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([targetType, normalizedTargetValue])
  @@index([status])
  @@index([expiresAt])
}

model NicknameBlacklist {
  id        String   @id @default(uuid())
  nickname  String   @unique
  createdAt DateTime @default(now())
}

model PrivilegeGroup {
  id          String @id @default(uuid())
  key         String @unique
  label       String
  color       String?
  permissions String[] @default([])

  privileges PlayerPrivilege[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlayerPrivilege {
  id          String @id @default(uuid())

  steamId     String?
  eosId       String?
  nickname    String?

  groupId     String
  group       PrivilegeGroup @relation(fields: [groupId], references: [id])

  comment     String?
  prefix      String?
  prefixColor String?
  imageUrl    String?

  active      Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([steamId])
  @@index([eosId])
  @@index([nickname])
  @@index([groupId])
}

model SquadServer {
  id        Int      @id
  name      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}